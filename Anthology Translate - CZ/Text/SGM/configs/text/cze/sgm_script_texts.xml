<!-- Překlad miniherního dialogu: -->

<string id="zat_sich_minigame_21_point_dialog_1">
	<text>Chtěl jsem se tě na něco zeptat.</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_2">
	<text>Na co se chceš zeptat?</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_3">
	<text>Letmo jsem zahlédl balíček karet za barem. Co kdybychom si zahráli oko, o peníze?</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_4">
	<text>Aha, tak o to jde. Dobře. Zahrajeme si! Připrav si peníze, já zatím zamíchám karty.</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_5">
	<text>Souhlasím. Peníze mám připravené.</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_6">
	<text>Fajn, já jsem taky připravený. Pojďme hrát.</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_7">
	<text>Zase to bude oko?</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_8">
	<text>Jo, jasně!</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_9">
	<text>Rozumím, jak vidíš, jsem už připravený. Jdeme na to.</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_10">
	<text>Zapomněl jsem. Zeptám se jindy.</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_11">
	<text>Jen ne oko, radši jindy.</text>
</string>
<string id="zat_sich_minigame_21_point_dialog_12">
	<text>Nesouhlasím, taková pravidla mi nevyhovují.</text>
</string>



<string_table>

	<string id="main_monolith_mlr_task_5_1_name_1">
    <text>Jdi do Sarkofágu</text>
</string>
<string id="main_monolith_mlr_task_5_1_name_2">
    <text>Najdi veškeré dostupné informace o skupině "Krystal"</text>
</string>
<string id="main_monolith_mlr_task_5_1_name_3">
    <text>Vrať se k Inkvizitorovi</text>
</string>
<string id="main_monolith_mlr_task_5_1_descr">
    <text>Inkvizitor mi navrhl, abych se osobně seznámil s kdysi legendární skupinou obránců Monolitu a zjistil o nich nějaké informace.</text>
</string>

<string id="main_monolith_mlr_task_3_2_name_1">
    <text>Znovuzrození: Promluv si s prvním bratrem</text>
</string>
<string id="main_monolith_mlr_task_3_2_name_2">
    <text>Znovuzrození: Promluv si s druhým bratrem</text>
</string>
<string id="main_monolith_mlr_task_3_2_name_3">
    <text>Znovuzrození: Promluv si s třetím bratrem</text>
</string>
<string id="main_monolith_mlr_task_3_2_name_4">
    <text>Znovuzrození: Promluv si se čtvrtým bratrem</text>
</string>
<string id="main_monolith_mlr_task_3_2_name_5">
    <text>Znovuzrození: Poděl se o myšlenky s Mentorem</text>
</string>
<string id="main_monolith_mlr_task_3_2_descr">
    <text>Hmmm, zajímavé... Zajímalo by mě, proč mě nepodezřívá?</text>
</string>

<string id="main_monolith_mlr_task_3_1_tip">
    <text>Dobrá, přestaň se hnát za pomstou a vrať se na Radar, naši vojáci potřebují pomoc. Promluv si s Gryphonem, vede naši skupinu "Křídla".</text>
</string>

<string id="agr_main_monolith_mlr_task_5_attack_done_message">
    <text>Mentor:\nProzatím se řiď rozkazy Inkvizitora, ještě tě budou potřebovat. Ke mně můžeš přijít později.</text>
</string>

<string id="main_monolith_mlr_task_5_descr">
    <text>Je třeba znovu obsadit Prádelnu od stalkerů.</text>
</string>
<string id="main_monolith_mlr_task_5_n_1">
    <text>Znovuzrození: Promluv si s Mentorem</text>
</string>
<string id="main_monolith_mlr_task_5_n_2">
    <text>Znovuzrození: Zaútoč na Prádelnu</text>
</string>
<string id="main_monolith_mlr_task_5_n_3">
    <text>Znovuzrození: Promluv si s Inkvizitorem</text>
</string>

<string id="main_monolith_mlr_task_5_dlg_1_mess_attack">
    <text>Inkvizitor:\nZačínáme, pospěš si.</text>
</string>

<string id="agr_main_monolith_mlr_task_5_doc">
    <text>Dokumentace k nedávno vydaným rozkazům</text>
</string>
<string id="agr_main_monolith_mlr_task_5_doc_desc">
    <text>Jediný dokument, který stojí za zmínku, je Rozkaz 66, který uvádí, že vzorek „Položka 62“ spolu s veškerou související dokumentací byl doručen do NIIChAZu.</text>
</string>

<string id="give_main_monolith_mlr_task_5_message">
    <text>Pokud máš čas, zastav se. Objevilo se něco celkem banálního.</text>
</string>

<string id="main_monolith_mlr_task_4_name_1">
    <text>Znovuzrození: Jdi do bunkru</text>
</string>
<string id="main_monolith_mlr_task_4_name_2">
    <text>Znovuzrození: Najdi řídící místnost</text>
</string>
<string id="main_monolith_mlr_task_4_name_3">
    <text>Znovuzrození: Promluv si s Gryphonem</text>
</string>
<string id="main_monolith_mlr_task_4_name_4">
    <text>Znovuzrození: Braň řídící místnost</text>
</string>
<string id="main_monolith_mlr_task_4_name_5">
    <text>Znovuzrození: Promluv si s Gryphonem</text>
</string>
<string id="main_monolith_mlr_task_4_descr">
    <text>Bratrstvo chce znovu použít "Spalovač". Doufám, že všechno půjde dobře.</text>
</string>

<string id="main_monolith_mlr_task_3_name_2">
    <text>Znovuzrození: Jdi na Radar</text>
</string>
<string id="main_monolith_mlr_task_3_name_3">
    <text>Znovuzrození: Promluv si s vůdcem "Křídel"</text>
</string>
<string id="main_monolith_mlr_task_3_descr">
    <text>Mentor mi sdělil, že naše skupina potřebuje pomoc na Radaru. Vypadá to, že se chystá něco velkého.</text>
</string>

<string id="main_monolith_mlr_task_3_1_name_1">
    <text>Znovuzrození: Vyčisti barikádu</text>
</string>
<string id="main_monolith_mlr_task_3_1_name_2">
    <text>Znovuzrození: Jdi na Radar</text>
</string>
<string id="main_monolith_mlr_task_3_1_name_3">
    <text>Znovuzrození: Promluv si s vůdcem "Křídel"</text>
</string>
<string id="main_monolith_mlr_task_3_1_descr">
    <text>Kdo mě do toho zatáhl... aspoň mi dali pár granátů.</text>
</string>

<string id="main_monolith_mlr_task_2_name_1">
    <text>Znovuzrození: Následuj Mentora</text>
</string>
<string id="main_monolith_mlr_task_2_name_2">
    <text>Znovuzrození: Promluv si s Mentorem</text>
</string>
<string id="main_monolith_mlr_task_2_name_3">
    <text>Znovuzrození: Zabij vězně</text>
</string>
<string id="main_monolith_mlr_task_2_name_4">
    <text>Znovuzrození: Promluv si s Mentorem</text>
</string>
<string id="main_monolith_mlr_task_2_descr">
    <text>Nevím, co se stane tentokrát.</text>
</string>

<string id="main_monolith_mlr_task_1_name_1">
    <text>Znovuzrození: Setkej se s ostatními</text>
</string>
<string id="main_monolith_mlr_task_1_name_2">
    <text>Znovuzrození: Poslechni si Mentora</text>
</string>
<string id="main_monolith_mlr_task_1_name_3">
    <text>Znovuzrození: Promluv si s Mentorem</text>
</string>
<string id="main_monolith_mlr_task_1_name_4">
    <text>Znovuzrození: Splň první zkoušku</text>
</string>
<string id="main_monolith_mlr_task_1_name_5">
    <text>Znovuzrození: Vrať se k Mentorovi</text>
</string>
<string id="main_monolith_mlr_task_1_descr">
    <text>Den, na který jsi čekal, konečně přišel. Projdi zkouškami a Monolit ti dá to, po čem nejvíce toužíš.</text>
</string>

<string id="main_monolith_mlr_task_4_dlg_1_in_bun_tip">
    <text>Gryphon:\nTeď musíme jít na konec komplexu. Dobře, chlapi, buďte opatrní – kdo ví, co nás tu čeká.</text>
</string>
<string id="main_monolith_mlr_task_4_dlg_1_in_heart_of_station_tip">
    <text>Gryphon:\nTady to je, řídící místnost. Upřímně, nevypadá to dobře. Dobře, vojáci, pojďme probrat další postup.</text>
</string>

<string id="main_monolith_mlr_task_3_tip">
    <text>Mentor:\nHej, ty úplně vlevo – brzy tě budu čekat, mám pro tebe nějakou práci.</text>
</string>
<string id="main_monolith_mlr_task_3_tip_2">
    <text>Mentor:\nTak co, hotovo? Škoda, že jsem neviděl jeho výraz, ha-ha-ha. Teď se vydej na Radar, naše průzkumná skupina "Křídla" tě tam čeká. Dostaneš se pod velení velitele a ten tě zasvětí.</text>
</string>

<string id="monolith_outfit_wings_name">
    <text>Kombinéza Monolitu "Křídla"</text>
</string>
<string id="monolith_outfit_wings_description">
    <text>Podobná standardní kombinéze Monolitu, avšak lehčí a pohodlnější než její předchůdce. Upravená pro nové podmínky Bratrstva, poskytuje lepší ochranu proti radiaci a psi-záření.</text>
</string>

<string id="mon_blue_box_mlr_no_use">
    <text>Tato bedna je zamčená.</text>
</string>

<string id="first_meet_words_mon_teacher">
    <text>Mentor:\nVítejte, vojáci nového Monolitu!</text>
</string>
<string id="second_meet_words_mon_teacher">
    <text>Mentor:\nJste naše jediná naděje na budoucnost, bratři. Brzy každého z vás zvlášť podrobím zkoušce, abych zjistil, zda si zasloužíte být v našich řadách.</text>
</string>
<string id="final_meet_words_mon_teacher">
    <text>Mentor:\nZatím máte volno. Všichni kromě tebe, ty úplně vlevo. Začnu tebou.</text>
</string>




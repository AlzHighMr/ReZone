<string id="st_sp_mod_achive_actor_good_name">
    <text>Pravý válečník</text>
</string>
<string id="st_sp_mod_achive_actor_good_descr">
    <text>Udělal jsi těžké rozhodnutí ve prospěch Institutu. Převzal jsi plnou odpovědnost za to, co se stane s tvým bratrem a přítelem...</text>
</string>
<string id="st_ach_mod_achive_actor_good">
    <text>Odemčeno ocenění „Věrný válečník“.</text>
</string>

<string id="st_sp_mod_achive_actor_bad_name">
    <text>Vlasti, promiň</text>
</string>
<string id="st_sp_mod_achive_actor_bad_descr">
    <text>Rozhodl ses pro svého bratra. Musel jsi jít proti Institutu – pevně jsi se rozhodl, že v takové situaci nejde o zájmy vlasti.</text>
</string>
<string id="st_ach_mod_achive_actor_bad">
    <text>Odemčeno ocenění „Vlasti, promiň“.</text>
</string>

<string id="st_sp_mod_achive_likvidator_name">

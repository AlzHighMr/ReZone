
;;--========================================
;;--===== Artifact Properties Reference ====
;;--========================================
;; Basic Properties
;------------------------------------------------------------
;               (cost)                                (af_rank)                                              (tier)                                 (degrade_rate)	          
;   Price of the artifact in game currency.   Artifact rarity or strength rank, usually 0-5.   Artifact tier, indicates general power level.      Artefact Degradation
;----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------                             
;             (inv_weight)                            (breeding_type)                          (additional_inventory_weight)           (additional_inventory_weight2) 
;  Inventory weight of the artifact.        Used for breeding/transmutating tiers.             Extra inventory weight capacity.        Secondary weight modifier.
;----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
;  Immunity Properties - Only works in Absorbation section
;------------------------------------------------------------
; (burn_immunity)     (shock_immunity) (chemical_burn_immunity)  (fire_wound_immunity)    (explosion_immunity)   (telepatic_immunity)      (strike_immunity)    (wound_immunity) 
;; 1%   = 0.00115      0.0389375           0.0002625                                                                                           0.010  
;; 1.5% = 0.00173      0.058406            0.000394                                                                                            0.015
;; 2%   = 0.00230      0.077875            0.000525                                                                                            0.020 
;; 2.5% = 0.00288      0.097344            0.000656                                                                                            0.025   
;; 5%   = 0.00575      0.194688            0.001312                                                                                            0.050  
;;----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
;Restore Properties
;------------------------------------------------------------
;; (bleeding_restore_speed) (health_restore_speed)  (power_restore_speed)    (radiation_restore_speed)     (satiety_restore_speed)
;; 1%   =  0.0000667             0.0001515              0.000200                     0.0000213
;; 1.5% =  0.0001000             0.0002273              0.000300                     0.0000319
;; 2%   =  0.0001333             0.0003030              0.000400                     0.0000426
;; 2.5% =  0.0001667             0.0003788              0.000500                     0.0000533
;; 5%   =  0.0003335             0.0007575              0.001000                     0.0001066
;;-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------



-------------------------------------------------------------------
-- Debug functions
-------------------------------------------------------------------

-- Draws cursor coodinates at cursor location with utils_ui.UIHint
function debug_position(UI, reference_UI, sub_x, sub_y)
	
	if not UI then return end

	-- Get cursor coordinates
	local pos = GetCursorPosition()
	local x = pos.x
	local y = pos.y
	
	-- Correct coordinates by reference
	local pos_ref
	local ref_str = ""
	local par_str = ""
	if reference_UI and reference_UI.GetWndPos then
		pos_ref = reference_UI:GetWndPos()
		x = x - pos_ref.x
		y = y - pos_ref.y
		
		ref_str = "Parent cursor: x=" .. round_string(x) .. ", y=" .. round_string(y) .. "                    "
		par_str = "Parent: x= " .. round_string(pos_ref.x) .. ", y=" .. round_string(pos_ref.y)
	end
	
	-- Correct coordinates manually
	if sub_x and tonumber(sub_x) then
		x = x - sub_x
	end
	if sub_y and tonumber(sub_y) then
		y = y - sub_y
	end
	
	-- Compile string, UI ignores newline characters
	-- utils_ui.UIHint window fits 41 numbers onto one line but letters have different spacing, so I can't automatically format line length
	local output = "Corrected cursor: x=" .. round_string(x) .. ", y=" .. round_string(y) .. "                 "
	output = output .. "Original cursor: x=" .. round_string(pos.x) .. ", y=" .. round_string(pos.y) .. "                 "
	output = output .. ref_str
	output = output .. par_str
	
	-- Draw coordinates
	UI:Update(output)
end

-------------------------------------------------------------------
-- Utility functions. For some weird reason the script doesn't recognize these function here anymore and need to be closer to where they're called from.
-------------------------------------------------------------------

-- Iterate over table keys and if section is in keys return true
function is_in_table_keys(table, section)
	for key, _ in pairs(table) do
		if (section == key) then
			return true
		end
	end
	return false
end

-- Round to precision, if precision is not defined, round to integer
function round(number, precision)
	local str
	if precision then
		local fmtStr = string.format('%%0.%sf',precision)
		str = string.format(fmtStr,number)
	else
		str = string.format("%.0f",number)
	end
	
	return tonumber(str)
end
-- Round to integer and convert to string
function round_string(x)
	return tostring(round(x))
end

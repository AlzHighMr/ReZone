[alife]
    schedule_min                = 3          ; milliseconds
    schedule_max                = 6          ; milliseconds
    process_time                = 600        ; microseconds
    objects_per_update          = 10
    update_monster_factor       = 0.1
    time_factor                 = 6          ; how many in-game seconds will pass per 1 real-life second
    normal_time_factor          = 10

;-- Online Switching Radius: objects inside this radius will switch online (game objects)
    switch_distance             = 325        ; [meters] default distance (engine)
    switch_factor               = 0.1        ; no idea what this does
    auto_switch                 = true       ; Enable automatic distance switching (xr_patch.script) for optimizing performance
    auto_switch_timer           = 10000      ; [milliseconds] (used if auto_switch is on) time required to switch from start to normal distance after loading
    auto_switch_distance_start  = 300        ; [meters] (used if auto_switch is on) switch_distance will set to this value upon loading for few seconds
    auto_switch_distance_normal = 325        ; [meters] (used if auto_switch is on) switch_distance will set to this value in normal case

    start_time                  = 08:30:00
    start_date                  = 25.10.2018
    autosave_interval           = 00:15:00
    delay_autosave_interval     = 00:00:30

    start_game_callback         = _G.start_game_callback   ; on starting new game or loading saved one

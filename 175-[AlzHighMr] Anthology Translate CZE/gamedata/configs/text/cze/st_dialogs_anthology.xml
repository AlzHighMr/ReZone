</string>


	
	<string id="zat_task_monolith_name">
    <text>Hrozba ze Staré cesty</text>
</string>
<string id="zat_task_monolith_descr">
    <text>Síly Monolitu získaly opěrný bod na Staré cestě a údajně připravují útok na Skadovsk. Vousáč chce, abys je zlikvidoval dřív, než bude pozdě.</text>
</string>

<string id="zat_task_spectrum_name">
    <text>Spektrum v Kurchatovu</text>
</string>
<string id="zat_task_spectrum_descr">
    <text>V Kurchatovu se objevila nová paramilitární skupina zvaná „Spektrum“. Jsou agresivní a dobře vycvičení. Vousáč chce, abys je odstranil, než způsobí další škody mezi stalkery.</text>
</string>

<string id="zat_task_sin_name">
    <text>Fanatici v lese</text>
</string>
<string id="zat_task_sin_descr">
    <text>V Prokletém lese se utvořila sekta zvaná „Hřích“. Jejich úmysly nejsou jasné, ale jejich nepřátelství ano. Vousáč chce, abys je vyhladil, než se rozšíří dál.</text>
</string>


	

#include "presets\trade_discounts.ltx"
#include "presets\trade_presets.ltx"

;;====================================================================================================================;;
;;==================| Profile |=======================================================================================;;
;;====================================================================================================================;;

[trader]
discounts                                        = discount_supplier

buy_condition                                    = trade_generic_buy
buy_supplies                                     = {=heavy_pockets_functor()} supplies_3, {=actor_goodwill_ge(killer:1000)} supplies_3, {=actor_goodwill_ge(killer:500)} supplies_2,  supplies_1
buy_item_condition_factor                        = 1.0
buy_item_exponent                                = 3.00

sell_condition                                   = trade_generic_sell
sell_item_exponent                               = 1.0

;;====================================================================================================================;;
;;==================| Player -> Trader Blacklist |====================================================================;;
;;====================================================================================================================;;

[trade_generic_buy]                              ; friend factor    , foe factor

;;====================================================================================================================;;
;;==================| Trader -> Player Blacklist |====================================================================;;
;;====================================================================================================================;;

[trade_generic_sell]                             ; friend factor    , foe factor




[logic]
active = ph_idle@check

[ph_idle@check]
on_info = {=actor_true_community(monolith:greh)} ph_idle@mstop, {+story_mode_disabled} ph_idle@stop, {+bar_deactivate_radar_done} ph_idle@stop, ph_idle@play

[ph_idle@base]
nonscript_usable = true

[ph_idle@play]:ph_idle@base
on_info = %+monolith_rad_outpost_megafone%
tips = Turn:Off
on_use = %=stop_sound% ph_idle@stop

[ph_idle@stop]:ph_idle@base
on_info = %-monolith_rad_outpost_megafone%
;on_info2 = {-bar_deactivate_radar_done} ph_idle@reset
tips = Turn:On
on_use = ph_idle@play

[ph_idle@reset]:ph_idle@base
tips = Turn:On
on_use = ph_idle@play
on_game_timer = 15500 | ph_idle@play

[ph_idle@mstop]:ph_idle@base
on_info = %-monolith_rad_outpost_megafone%
tips = Turn:On
on_use = ph_idle@mplay

[ph_idle@mplay]:ph_idle@base
on_info = %+monolith_rad_outpost_megafone%
on_info2 = {+bar_deactivate_radar_done} ph_idle@mreset
tips = Turn:Off
on_use = %=stop_sound% ph_idle@mstop

[ph_idle@mreset]:ph_idle@base
tips = Turn:Off
on_use = ph_idle@mstop
on_game_timer = 15500 | ph_idle@mstop %=stop_sound%

[collide]
ignore_static

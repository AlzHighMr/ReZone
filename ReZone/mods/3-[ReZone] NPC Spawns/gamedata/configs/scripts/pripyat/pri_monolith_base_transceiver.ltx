[logic]
active = ph_idle@check

[ph_idle@check]
on_info = ph_idle@play ;{=actor_community(actor_monolith)} ph_idle@mstop, {=actor_community(actor_greh)} ph_idle@mstop, 

[ph_idle@base]
nonscript_usable = true

[ph_idle@play]:ph_idle@base
on_info = %+monolith_pri_base_megafone%
tips = Turn:Off
on_use = %=stop_sound% ph_idle@stop

[ph_idle@stop]:ph_idle@base
on_info = %-monolith_pri_base_megafone%
on_info2 = {-pri_monolith_haron_dead} ph_idle@reset, ph_idle@stop %=stop_sound%
tips = Turn:On
on_use = ph_idle@play

[ph_idle@reset]:ph_idle@base
tips = Turn:On
on_use = ph_idle@play
on_game_timer = 15500 | ph_idle@play

[ph_idle@mstop]:ph_idle@base
on_info = %-monolith_pri_base_megafone%
tips = Turn:On
on_use = ph_idle@mplay

[ph_idle@mplay]:ph_idle@base
on_info = %+monolith_pri_base_megafone%
on_info2 = {+pri_monolith_haron_dead} ph_idle@mreset, ph_idle@mplay
tips = Turn:Off
on_use = %=stop_sound% ph_idle@mstop

[ph_idle@mreset]:ph_idle@base
tips = Turn:Off
on_use = ph_idle@mstop
on_game_timer = 15500 | ph_idle@mstop %=stop_sound%

[collide]
ignore_static

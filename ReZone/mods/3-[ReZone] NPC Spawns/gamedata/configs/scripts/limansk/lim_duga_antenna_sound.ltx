[logic]
active = ph_idle@on

[ph_idle@on]
on_info = %=play_sound_looped(duga_antenna_sound_on)%
on_info2 = {+lim_deactivate_duga_done} ph_idle@off %=stop_sound%

[ph_idle@off]
on_info = %=play_sound(duga_antenna_sound_off)%
on_signal = sound_end | ph_idle@nil

[ph_idle@nil]
on_info = {-lim_deactivate_duga_done} ph_idle@on

[collide]
ignore_static

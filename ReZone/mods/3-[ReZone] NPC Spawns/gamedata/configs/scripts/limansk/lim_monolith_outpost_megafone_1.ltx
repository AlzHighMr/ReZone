[logic]
active = {+monolith_lim_outpost_megafone_1} ph_idle@play, ph_idle@stop %=stop_sound%

[ph_idle@play]
nonscript_usable = false
on_info = {+monolith_lim_outpost_megafone_1} %=play_sound(monolith_lim_outpost_speech)%, %=stop_sound% ph_idle@stop

[ph_idle@stop]
nonscript_usable = false
on_info = {+monolith_lim_outpost_megafone_1} ph_idle@play

[collide]
ignore_static






	<string id="ui_mcm_drx_da_anomaly_zone_spawn_chance">
		<text>Šance na spawn anomální zóny</text>
	</string>
	<string id="ui_mcm_drx_da_anomaly_zone_spawn_chance_desc">
		<text>Šance, že se na předem definovaném chytrém terénu vyskytne anomální zóna</text>
	</string>

	<string id="ui_mcm_drx_da_anomaly_zone_anomalies_distance_max">
		<text>Rádius anomální zóny</text>
	</string>
	<string id="ui_mcm_drx_da_anomaly_zone_anomalies_distance_max_desc">
		<text>Maximální vzdálenost od středu chytrého terénu, která je povolena pro zónu anomálií</text>.
	</string>

	<string id="ui_mcm_drx_da_anomaly_zone_anomalies_distance_min">
		<text>Minimální vzdálenost mezi anomáliemi</text>
	</string>
	<string id="ui_mcm_drx_da_anomaly_zone_anomalies_distance_min_desc">
		<text>Definuje minimální vzdálenost mezi anomáliemi v zóně. Záporné hodnoty umožní, aby se anomálie vzájemně překrývaly</text>
	</string>

	<string id="ui_mcm_drx_da_anomaly_amount_modifier">
		<text>Modifikátor množství anomálií</text>
	</string>
	<string id="ui_mcm_drx_da_anomaly_amount_modifier_desc">
		<text>Modifikuje množství anomálií, které může mít každá anomální zóna</text>.
	</string>

	<string id="ui_mcm_drx_da_max_artefacts_per_zone">
		<text>Max artefakty na zónu</text>
	</string>
	<string id="ui_mcm_drx_da_max_artefacts_per_zone_desc">
		<text>Definuje maximální množství artefaktů, které se mohou objevit v zóně anomálie</text>.
	</string>

	<string id="ui_mcm_drx_da_artefacts_spawn_chance">
		<text>Šance na spawn artefaktů</text>
	</string>
	<string id="ui_mcm_drx_da_artefacts_spawn_chance_desc">
		<text>Každý z definovaného maximálního množství artefaktů bude mít tuto šanci na spawn</text>
	</string>

	<string id="ui_mcm_drx_da_random_artefact_spawn_chance">
		<text>Náhodná šance na spawn artefaktů</text>
	</string>
	<string id="ui_mcm_drx_da_random_artefact_spawn_chance_desc">
		<text>Které artefakty mohou být spawnovány, je definováno úrovní. Jižní lokace mohou spawnovat pouze slabé artefakty, zatímco podzemní a severní mohou spawnovat silné artefakty. Existuje však šance, definovaná touto hodnotou, že anomální zóna může spawnovat jakýkoli artefakt, včetně unikátních</text>.
	</string>

	<string id="ui_mcm_drx_da_gravitational_shake_modifier">
		<text>Modifikátor gravitačního chvění</text>
	</string>
	<string id="ui_mcm_drx_da_gravitational_shake_modifier_desc">
		<text>Modifikátor chvění obrazovky v blízkosti gravitačních anomálií</text>
	</string>

	<string id="ui_mcm_drx_da_electric_field_modifier">
		<text>Modifikátor elektrického pole</text>
	</string>
	<string id="ui_mcm_drx_da_electric_field_modifier_desc">
		<text>Modifikátor poškození elektrického pole. Nemá vliv na závady elektronických zařízení</text>
	</string>

	<string id="ui_mcm_drx_da_enable_anomalies_behaviour">
		<text>Povolit dynamické chování anomálií</text>
	</string>
	<string id="ui_mcm_drx_da_enable_anomalies_behaviour_desc">
		<text>Definuje, zda mají mít dynamické anomálie zvláštní chování a mohou se v zóně objevovat a mizet</text>.
	</string>

	<string id="ui_mcm_drx_da_save_after_cleanup">
		<text>Uložit hru po odstranění anomálií</text>
	</string>
	<string id="ui_mcm_drx_da_save_after_cleanup_desc">
		<text>Uloží hru po emisi nebo psi-bouři, když jsou z úrovně odstraněny dynamické anomálie</text>.
	</string>



<string id="ui_mcm_drx_da_disable_new_anomalies">
		<text>Zakázat nové anomálie</text>
	</string>
	<string id="ui_mcm_drx_da_disable_new_anomalies_desc">
		<text>Zakáže vytváření nových druhů anomálií. Volba se projeví po příští emisi nebo psy-storm nebo při nové hře</text>
	</string>

	<string id="ui_mcm_drx_da_choose_help">
